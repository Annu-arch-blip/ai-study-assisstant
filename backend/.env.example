# ===== SERVER =====
PORT=5000
NODE_ENV=development

# ===== DATABASE =====
# Get this from MongoDB Atlas (you've set this up before)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai-study-quiz?retryWrites=true&w=majority

# ===== AUTH =====
# Generate a random secret: run `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ===== AI (Groq) =====
# Get a FREE key from https://console.groq.com/keys (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ===== CORS =====
FRONTEND_URL=http://localhost:5173

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100